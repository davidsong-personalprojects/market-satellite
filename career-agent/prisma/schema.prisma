generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MasterResume {
  id        Int      @id @default(1)
  content   String
  updatedAt DateTime @updatedAt
}

model Application {
  id              Int             @id @default(autoincrement())
  companyName     String
  jobTitle        String
  industry        String
  jobUrl          String?
  jobDescription  String
  companyResearch Json?
  createdAt       DateTime        @default(now())
  versions        ResumeVersion[]
  messages        ChatMessage[]
}

model ResumeVersion {
  id            Int         @id @default(autoincrement())
  applicationId Int
  versionNumber Int
  content       String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])
}

model ChatMessage {
  id            Int         @id @default(autoincrement())
  applicationId Int
  role          MessageRole
  content       String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])
}

enum MessageRole {
  user
  assistant
}
